<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<TabPane xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="controller.EmployeController"
         tabClosingPolicy="UNAVAILABLE">

    <!-- ONGLET DÉPARTEMENTS -->
    <tabs>
        <Tab text="Départements">
            <content>
                <VBox spacing="10">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <Label text="Gestion des Départements" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <HBox spacing="10">
                        <Label text="Nom du département :"/>
                        <TextField fx:id="tfNomDept" promptText="Ex: Informatique" prefWidth="200"/>
                        <Button text="Ajouter"    onAction="#ajouterDepartement"/>
                        <Button text="Modifier"   onAction="#modifierDepartement"/>
                        <Button text="Supprimer"  onAction="#supprimerDepartement"/>
                    </HBox>

                    <TableView fx:id="tableDepts" prefHeight="300" onMouseClicked="#selectionnerDepartement">
                        <columns>
                            <TableColumn fx:id="colDeptId"  text="ID"          prefWidth="60"/>
                            <TableColumn fx:id="colDeptNom" text="Département"  prefWidth="300"/>
                        </columns>
                    </TableView>

                </VBox>
            </content>
        </Tab>

        <!-- ONGLET EMPLOYÉS -->
        <Tab text="Employés">
            <content>
                <VBox spacing="10">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <Label text="Gestion des Employés" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <!-- Formulaire -->
                    <HBox spacing="10">
                        <Label text="Nom :"/>
                        <TextField fx:id="tfNom" promptText="Nom" prefWidth="120"/>
                        <Label text="Prénom :"/>
                        <TextField fx:id="tfPrenom" promptText="Prénom" prefWidth="120"/>
                        <Label text="Poste :"/>
                        <TextField fx:id="tfPoste" promptText="Poste" prefWidth="120"/>
                    </HBox>

                    <HBox spacing="10">
                        <Label text="Salaire :"/>
                        <TextField fx:id="tfSalaire" promptText="Ex: 750000" prefWidth="120"/>
                        <Label text="Département :"/>
                        <ComboBox fx:id="cbDepartement" prefWidth="180"/>
                        <Button text="Ajouter"      onAction="#ajouterEmploye"/>
                        <Button text="Modifier"     onAction="#modifierEmploye"/>
                        <Button text="Supprimer"    onAction="#supprimerEmploye"/>
                        <Button text="Réinitialiser" onAction="#reinitialiserFormulaire"/>
                    </HBox>

                    <!-- Recherche -->
                    <HBox spacing="10">
                        <Label text="Rechercher :"/>
                        <TextField fx:id="tfRecherche" promptText="Nom, prénom ou poste..."
                                   prefWidth="200"/>
                        <Button text="Rechercher" onAction="#rechercherEmploye"/>
                        <Label text="Département :"/>
                        <ComboBox fx:id="cbFiltre" prefWidth="180" promptText="-- Tous --"/>
                        <Button text="Filtrer" onAction="#filtrerParDepartement"/>
                        <Button text="Tous" onAction="#afficherTous"/>
                    </HBox>

                    <!-- Table -->
                    <TableView fx:id="tableEmployes" prefHeight="300" onMouseClicked="#selectionnerEmploye">
                        <columns>
                            <TableColumn fx:id="colEmpId"      text="ID"          prefWidth="50"/>
                            <TableColumn fx:id="colEmpNom"     text="Nom"         prefWidth="120"/>
                            <TableColumn fx:id="colEmpPrenom"  text="Prénom"      prefWidth="120"/>
                            <TableColumn fx:id="colEmpPoste"   text="Poste"       prefWidth="150"/>
                            <TableColumn fx:id="colEmpSalaire" text="Salaire"     prefWidth="120"/>
                            <TableColumn fx:id="colEmpDept"    text="Département" prefWidth="150"/>
                        </columns>
                    </TableView>

                    <Label fx:id="lblMasse" style="-fx-font-weight: bold;"/>

                </VBox>
            </content>
        </Tab>
    </tabs>
</TabPane>